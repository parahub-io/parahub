# __DOMAIN__ — Main Parahub instance
# Generated by nginx/setup-nginx.sh — edit template, not this file

upstream parahub_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

upstream parahub_frontend {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    server_name __DOMAIN__ www.__DOMAIN__;

    client_max_body_size 100M;
    keepalive_timeout 65;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Content Security Policy
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.__DOMAIN__; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' blob: wss://__DOMAIN__ https://*.__DOMAIN__ https://api.coingecko.com https://mempool.space; worker-src 'self' blob:; child-src 'self' blob: https://git.__DOMAIN__ https://jitsi.__DOMAIN__ https://video.__DOMAIN__; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://mail.__DOMAIN__;" always;

    # Static files
    location /static/ {
        alias __PROJECT_DIR__/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Private media — only via X-Accel-Redirect from Django
    location /media/private/ {
        internal;
        alias __PROJECT_DIR__/media/private/;
    }
    location /media/ {
        alias __PROJECT_DIR__/media/;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
    }

    # WebSocket support for Django Channels
    location /ws/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_connect_timeout 7d;
        proxy_send_timeout 7d;
        proxy_read_timeout 7d;
    }

    # LNURL-pay endpoint for Lightning addresses (user@__DOMAIN__)
    location /.well-known/lnurlp/ {
        proxy_pass http://parahub_backend/api/v1/lnurl/.well-known/lnurlp/;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        if ($request_method = OPTIONS) {
            return 204;
        }
    }

    # Map Font Glyphs (PBF)
    location /fonts/ {
        alias __PROJECT_DIR__/static/fonts/;
        expires 365d;
        add_header Cache-Control "public, immutable";
        add_header Access-Control-Allow-Origin "*";
    }

    # Video upload endpoint — allow 4GB uploads (PeerTube proxy)
    location = /api/v1/core/videos/upload/ {
        client_max_body_size 4096M;
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_connect_timeout 600s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;
        proxy_request_buffering off;
    }

    # OpenSky upload endpoint — allow 2GB uploads
    location = /api/v1/geo/opensky/upload/ {
        client_max_body_size 2048M;
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # MOTIS transit routing (journey planning)
    location /api/v1/routing/transit {
        rewrite ^/api/v1/routing/transit(.*)$ /api/v5/plan$1 break;
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Valhalla Routing Engine (route, isochrone, trace, matrix, height)
    location /api/v1/routing/ {
        rewrite ^/api/v1/routing/(.*)$ /$1 break;
        proxy_pass http://127.0.0.1:8002;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_connect_timeout 30s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
    }

    # Geocoding API (handled by Nuxt frontend)
    location /api/geocode/ {
        proxy_pass http://parahub_frontend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_buffering off;
    }

    # API endpoints
    location /api/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffering off;
    }

    # Admin interface
    location /admin/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # OAuth and auth endpoints (Django)
    location /accounts/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # Mobile OAuth completion (Capacitor app flow)
    location /auth/mobile-complete/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # OAuth2/OIDC Provider
    location /o/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # Matrix/Synapse endpoints
    location ~* ^(\/_matrix|\/_synapse\/(client|admin).*) {
        proxy_pass http://localhost:8008;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
        client_max_body_size 100M;
        proxy_buffering off;
        proxy_http_version 1.1;
        proxy_hide_header Content-Security-Policy;
        proxy_hide_header X-Frame-Options;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header Content-Security-Policy "frame-ancestors 'self'" always;
    }

    # Android App Links verification
    location ^~ /.well-known/assetlinks.json {
        alias __PROJECT_DIR__/frontend/public/.well-known/assetlinks.json;
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
    }

    # Matrix well-known endpoints
    location ^~ /.well-known/matrix/server {
        return 200 '{"m.server": "__DOMAIN__:443"}';
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }

    location ^~ /.well-known/matrix/client {
        return 200 '{"m.homeserver": {"base_url": "https://__DOMAIN__"}, "m.identity_server": {"base_url": "https://vector.im"}}';
        add_header Content-Type application/json;
        add_header Access-Control-Allow-Origin *;
    }

    # Element Web static files (Matrix client in /chat iframe)
    location = /element {
        return 301 /element/;
    }
    location /element/ {
        alias __PROJECT_DIR__/element/;
        try_files $uri $uri/ /element/index.html;
        add_header Set-Cookie "element_mobile_redirect_to_guide=false; Path=/; Max-Age=31536000; SameSite=Lax" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        location ~ ^/element/bundles/ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # Cinny Web static files (Matrix client)
    location = /cinny {
        return 301 /cinny/;
    }
    location /cinny/ {
        alias __PROJECT_DIR__/cinny/;
        try_files $uri $uri/ /cinny/index.html;
        add_header X-Frame-Options "SAMEORIGIN" always;
        location = /cinny/index.html {
            alias __PROJECT_DIR__/cinny/index.html;
            add_header Cache-Control "no-cache, must-revalidate";
            add_header X-Frame-Options "SAMEORIGIN" always;
        }
        location ~ ^/cinny/(assets|public)/ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # Plausible Analytics (ad-blocker bypass proxy)
    location /plausible/ {
        proxy_pass http://127.0.0.1:8091/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
    }

    # Direct Django logout
    location /logout/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # Traccar Web UI proxy
    location /traccar/ {
        proxy_pass http://localhost:8082/;
        proxy_redirect http://localhost:8082/ /traccar/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /traccar/api/ {
        proxy_pass http://localhost:8082/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # OIDC Discovery endpoints
    location ^~ /.well-known/openid-configuration {
        proxy_pass http://parahub_backend/oauth/.well-known/openid-configuration;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    location ^~ /.well-known/jwks.json {
        proxy_pass http://parahub_backend/oauth/.well-known/jwks.json;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    location ~ ^/o/\.well-known/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
    }

    # Nuxt static assets
    location /_nuxt/ {
        proxy_pass http://parahub_frontend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Vue/Nuxt application (everything else)
    location / {
        proxy_pass http://parahub_frontend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
    }

    # Deny access to hidden files (except .well-known)
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    access_log /var/log/nginx/parahub_access.log;
    error_log /var/log/nginx/parahub_error.log;

    # SSL — run: sudo certbot --nginx -d __DOMAIN__ -d www.__DOMAIN__
    listen 80;
    listen [::]:80;
}

# HTTP to HTTPS redirect (certbot will modify this)
server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__ www.__DOMAIN__;
    return 301 https://$host$request_uri;
}
