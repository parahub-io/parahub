# CMS Mini-sites: *.org.__DOMAIN__ and *.u.__DOMAIN__
# Generated by nginx/setup-nginx.sh

# HTTP → HTTPS redirect
server {
    listen 80;
    server_name *.org.__DOMAIN__ *.u.__DOMAIN__ org.__DOMAIN__ u.__DOMAIN__;
    return 301 https://$host$request_uri;
}

# Bare subdomain stubs (no slug → static page)
server {
    listen 443 ssl;
    server_name org.__DOMAIN__;

    ssl_certificate /etc/letsencrypt/live/org.__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/org.__DOMAIN__/privkey.pem;

    location /images/para/ {
        alias __PROJECT_DIR__/frontend/public/images/para/;
        expires 30d;
        access_log off;
    }

    location / {
        default_type text/html;
        alias __PROJECT_DIR__/static/stubs/;
        try_files /org.html =404;
    }
}

server {
    listen 443 ssl;
    server_name u.__DOMAIN__;

    ssl_certificate /etc/letsencrypt/live/u.__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/u.__DOMAIN__/privkey.pem;

    location /images/para/ {
        alias __PROJECT_DIR__/frontend/public/images/para/;
        expires 30d;
        access_log off;
    }

    location / {
        default_type text/html;
        alias __PROJECT_DIR__/static/stubs/;
        try_files /user.html =404;
    }
}

# Organization mini-sites
server {
    listen 443 ssl;
    server_name *.org.__DOMAIN__;

    ssl_certificate /etc/letsencrypt/live/org.__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/org.__DOMAIN__/privkey.pem;

    client_max_body_size 20M;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.__DOMAIN__; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' blob: wss://__DOMAIN__ https://*.__DOMAIN__ https://api.coingecko.com https://mempool.space; worker-src 'self' blob:; child-src 'self' blob: https://video.__DOMAIN__; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" always;

    location /api/ {
        proxy_pass http://parahub_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
    }

    location /static/ {
        alias __PROJECT_DIR__/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location /media/ {
        alias __PROJECT_DIR__/media/;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
    }

    location / {
        proxy_pass http://parahub_frontend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
    }
}

