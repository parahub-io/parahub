# =============================================================================
# Parahub Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env
# Or run ./install.sh to generate automatically
# =============================================================================

# ==================== DJANGO CORE ====================
SECRET_KEY=change-me-generate-with-python-c-from-django.core.management.utils-import-get_random_secret_key-print(get_random_secret_key())
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,parahub.io
CSRF_TRUSTED_ORIGINS=https://parahub.io
CORS_ALLOWED_ORIGINS=https://parahub.io
SECURE_SSL_REDIRECT=False
SITE_URL=https://parahub.io
PARAHUB_SERVER_IP=
# DJANGO_LOG_LEVEL=INFO

# ==================== DATABASES ====================
# Main PostgreSQL (PostGIS)
DATABASE_URL=postgres://parahub:CHANGE_ME@localhost:5432/parahub
DB_PASSWORD=CHANGE_ME

# Traccar PostgreSQL
TRACCAR_DB_PASSWORD=CHANGE_ME
TRACCAR_EMAIL_DOMAIN=parahub.io
TRACCAR_PUBLIC_HOST=
# TRACCAR_DB_HOST=localhost
# TRACCAR_DB_PORT=5435
# TRACCAR_DB_NAME=traccar
# TRACCAR_DB_USER=traccar

# Synapse PostgreSQL
SYNAPSE_DB_PASSWORD=CHANGE_ME

# Neo4j Graph Database
NEO4J_PASSWORD=CHANGE_ME
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_DATABASE=neo4j

# Redis (defaults to localhost:6379)
# REDIS_HOST=127.0.0.1
# REDIS_URL=redis://localhost:6379/1

# OpenMapTiles (optional)
# OPENMAPTILES_DB_HOST=localhost
# OPENMAPTILES_DB_PASSWORD=openmaptiles
# OPENMAPTILES_DB_PORT=5439

# ==================== AUTHENTICATION ====================
# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for mail passwords (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# ==================== AI / VOICE ====================
# ElevenLabs API key for voice support bot (optional)
# ELEVENLABS_API_KEY=
# Google AI API key is stored in Django admin (AISettings model), not here

# ==================== FIREBASE (FCM Push) ====================
# Path to Firebase service account JSON for native push notifications (optional)
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT=/opt/parahub/.secrets/firebase-service-account.json

# ==================== OIDC INTEGRATION ====================
OIDC_ISSUER=https://parahub.io
TRACCAR_OIDC_CLIENT_SECRET=
SYNAPSE_OIDC_CLIENT_SECRET=
GITEA_OIDC_CLIENT_SECRET=
PEERTUBE_OIDC_CLIENT_SECRET=

# ==================== MATRIX / SYNAPSE ====================
SYNAPSE_REGISTRATION_SHARED_SECRET=CHANGE_ME
SYNAPSE_ADMIN_TOKEN=
SYNAPSE_ADMIN_USER=
SYNAPSE_ADMIN_PASSWORD=CHANGE_ME

# ==================== WEB PUSH (VAPID) ====================
# Generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY_PEM=""
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=admin@parahub.io

# ==================== JITSI MEET ====================
# Generate: openssl rand -hex 64
JITSI_JWT_SECRET=
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=

# ==================== TURN SERVER ====================
# Generate: openssl rand -hex 32
TURN_SECRET=

# ==================== EMAIL / MAILCOW ====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=127.0.0.1
EMAIL_PORT=25
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

MAILCOW_API_URL=https://127.0.0.1:8444
MAILCOW_API_KEY=
MAILCOW_DOMAIN=parahub.io
MAILCOW_DEFAULT_QUOTA_MB=1024

# ==================== MESH NETWORK ====================
MESH_HEARTBEAT_KEY=
MESH_DEFAULT_OWNER_PROFILE_ID=
MESH_SSH_KEY_PATH=~/.ssh/id_ed25519
MESH_VPS_WG_PUBKEY=
MESH_VPS_WG_ENDPOINT=
# MESH_SUBSCRIPTION_PRICE_SATS=50000
# MESH_SUBSCRIPTION_DURATION_DAYS=30
# MESH_LNBITS_URL=
# MESH_LNBITS_INVOICE_KEY=

# ==================== FEDERATION ====================
FEDERATION_ENABLED=False
FEDERATION_DOMAIN=parahub.io
FEDERATION_NODE_PGP_FINGERPRINT=

# ==================== AUDIT ====================
# AUDIT_LOG_PUBLIC_GIT_REMOTE=
OPENTIMESTAMPS_ENABLED=True

# ==================== ANALYTICS (optional) ====================
# PLAUSIBLE_DB_PASSWORD=CHANGE_ME
# PLAUSIBLE_SECRET_KEY=CHANGE_ME

# ==================== GITEA ====================
# DB_PASSWORD is reused for Gitea (same main PostgreSQL)
# Shared secret for Gitea → Django webhooks (generate: openssl rand -hex 32)
GITEA_WEBHOOK_SECRET=

# ==================== INCIDENTS (Uptime Kuma) ====================
# Shared secret for Uptime Kuma → Django incident webhook (generate: openssl rand -hex 32)
INCIDENT_WEBHOOK_SECRET=

# ==================== PEERTUBE ====================
# Generate: openssl rand -hex 32
PEERTUBE_SECRET=

# ==================== CIVIC POLLS ====================
# HMAC key for pseudonymous ballot identifiers (GDPR Art.9). Losing it breaks
# double-vote detection for open polls; never rotate mid-poll.
# Generate: openssl rand -hex 32
CIVIC_VOTE_SECRET=

# ==================== SUPERUSER ====================
SUPERUSER_PASSWORD=CHANGE_ME
